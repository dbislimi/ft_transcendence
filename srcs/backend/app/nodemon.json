{
  "watch": ["src"],
  "ext": "ts,js,json",
  "exec": "node --no-deprecation -r ts-node/register src/server.ts",
  "ignore": [
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "dist/**/*",
    "node_modules/**/*",
    "../AI/**/*"
  ],
  "delay": 1000,
  "env": {
    "NODE_ENV": "development"
  }
}
