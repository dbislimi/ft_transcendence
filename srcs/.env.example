# Hostname/IP address for the application
HOSTNAME=localhost

# JWT Secret for token signing (REQUIRED)
# Generate a secure random string, e.g., with: openssl rand -base64 32
JWT_SECRET=your-secret-key-here-change-me

# Google OAuth credentials (REQUIRED if using Google authentication)
# Get these from https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
